# ==============================================================================
#  deploy/.env.example   –   Copy to .env and fill in the values
#
#  The real .env is gitignored. This file documents every required variable.
#  On the VPS: cp .env.example .env  then edit .env
# ==============================================================================

# ── Docker image registry ─────────────────────────────────────────────────────
# Images are built by CI (GitHub Actions) and pushed to GHCR.
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_BACKEND=psa-avat/club-erp-backend
DOCKER_IMAGE_FRONTEND=psa-avat/club-erp-frontend
IMAGE_TAG=latest

# ── Database ──────────────────────────────────────────────────────────────────
# The ERP uses its own database (erp_club_db) inside the shared carnet-db
# postgres container, connected via db_network (see README §5).
POSTGRES_DB=erp_club_db
POSTGRES_USER=erpuser
POSTGRES_PASSWORD=CHANGE_ME

# Full async URL – carnet-db is the shared postgres container name on db_network
DATABASE_URL=postgresql+asyncpg://erpuser:CHANGE_ME@carnet-db:5432/erp_club_db

# ── Security (JWT) ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── Domain ────────────────────────────────────────────────────────────────────
# Wildcard DNS *.erp-club.psa-avat.fr covers this hostname.
# The frontend serves the SPA and proxies /api to the backend internally.
ERP_HOST=avat.erp-club.psa-avat.fr

# ── CORS ─────────────────────────────────────────────────────────────────────
# The frontend proxies /api so the browser origin is the same domain.
# Only add extra origins if the API needs to be called from other frontends.
CORS_ORIGINS=https://avat.erp-club.psa-avat.fr

# ── Gesasso integration (optional) ────────────────────────────────────────────
GESASSO_API_URL=https://gesasso.ffvp.fr/api
GESASSO_USER=
GESASSO_SECRET=
